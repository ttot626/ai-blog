# 复制为 .env 后修改（.env 已被 .gitignore 忽略，不会提交到 Git）
# cp .env.example .env

# 对外端口（浏览器访问 http://服务器IP:8080）
APP_PORT=8080

# MySQL 密码（必填，生产环境请用强密码）
DB_PASSWORD=your_strong_password

# JWT 签名密钥（必填，随机长字符串，至少 32 位）
JWT_SECRET=your_random_jwt_secret_at_least_32_chars

# DeepSeek AI（可选，用于摘要/标题/关键词/标签生成）
# 获取地址：https://platform.deepseek.com/api_keys
# 修改后需执行：docker compose up -d --force-recreate app
DEEPSEEK_API_KEY=
